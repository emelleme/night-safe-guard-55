# Security + caching for CardCtrl on Cloudflare Pages
# nfc=(self) is required so Chrome Android does not block Web NFC via Permissions-Policy

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: nfc=(self), camera=(self), accelerometer=(), geolocation=(), gyroscope=(), microphone=()
  X-Frame-Options: DENY

# Hashed Vite assets — long cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML shell — always revalidate
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
