{
  "name": "cardctrl",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "pages:build": "pnpm install && pnpm run build",
    "pages:dev": "wrangler pages dev dist",
    "deploy": "pnpm run build && wrangler pages deploy dist --project-name=cardctrl",
    "deploy:preview": "pnpm run build && wrangler pages deploy dist --project-name=cardctrl --branch=preview"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "22.19.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.1",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "typescript": "^5",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.1.3",
    "wrangler": "^4.28.0"
  }
}
